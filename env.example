# === AI MULTI-AGENT MVP GENERATION SYSTEM ===
# Copy this file to .env and fill in your actual values

# === GENERAL SETTINGS ===
MODE=demo  # demo or full
LOG_LEVEL=INFO
SEARCH_KEYWORDS=бот,данные,скрипт,парсер,api
MAX_PROJECTS_PER_SESSION=5
EVALUATION_THRESHOLD=0.4
SESSION_DURATION_MAX=300
PAUSE_BETWEEN_CHECKS=3600
READING_TIME_MIN=10
READING_TIME_MAX=30

# === KWORK CREDENTIALS (required for MODE=full) ===
KWORK_EMAIL=your_email@kwork.ru
KWORK_PASSWORD=your_password

# === TELEGRAM NOTIFICATIONS ===
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHANNEL_ID=@your_channel_username

# === GEMINI / AI SETTINGS ===
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=models/gemini-2.0-flash
SEMANTIC_SIMILARITY_THRESHOLD=0.5

# === AGENT B (MVP Generation) ===
# GitHub integration
GITHUB_USER=your_github_username
GITHUB_TOKEN=your_github_token
AGENT_B_TEST_MODE=true
AGENT_B_TEST_REPO=mvp-test

# Vercel deployment (optional)
VERCEL_TOKEN=your_vercel_token
# VERCEL_TEAM_ID=team_xxxxx (если используете команду)

# ==== External API keys / URLs for MVP templates ====
NEWSAPI_KEY=a4ac8558514949c9b79db183bd5a2502
FAKESTORE_API_URL=https://fakestoreapi.com/products
QUOTES_API_URL=http://quotes.toscrape.com/
SPACEX_API_URL=https://api.spacexdata.com/v5/launches
